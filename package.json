{
  "name": "appium-wdio-portfolio",
  "version": "0.1.0",
  "description": "Mobile automation portfolio example using Appium, WebdriverIO, Cucumber, and TypeScript.",
  "private": true,
  "scripts": {
    "test": "npx wdio run wdio.conf.ts",
    "test:android": "npx wdio run wdio.conf.ts --spec ./features/**/*.feature",
    "test:headless": "npx wdio run wdio.conf.ts --spec ./features/**/*.feature",
    "clean": "rm -rf ./reports/*",
    "format": "npx prettier --write '**/*.{ts,md,json}'"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^9.0.0",
    "@wdio/appium-service": "^8.20.4",
    "@wdio/cli": "^8.20.4",
    "@wdio/cucumber-framework": "^8.20.4",
    "@wdio/local-runner": "^8.20.4",
    "@wdio/spec-reporter": "^8.20.4",
    "@wdio/types": "^8.20.4",
    "@wdio/utils": "^8.20.4",
    "@types/chai": "^4.3.5",
    "@types/node": "^20.11.0",
    "appium": "^2.0.0",
    "chai": "^4.3.8",
    "dotenv": "^16.3.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.0",
    "webdriverio": "^8.20.4"
  }
}
