{
  "name": "appium-wdio-portfolio",
  "version": "0.1.0",
  "description": "Mobile automation portfolio example using Appium, WebdriverIO, Cucumber, and TypeScript.",
  "private": true,
  "scripts": {
    "test": "node scripts/ci-validate.js",
    "test:ci": "node scripts/ci-validate.js",
    "appium": "npx appium --base-path / --address ${APPIUM_HOST:-0.0.0.0} --port ${APPIUM_PORT:-4723} --relaxed-security --allow-insecure chromedriver_autodownload",
    "test:sauce": "npx wdio run wdio.conf.cjs",
    "test:android": "node scripts/run-android.js",
    "test:ios": "node scripts/run-ios.js",
    "test:headed": "WDIO_HEADED=true node scripts/run-android.js",
    "clean": "rm -rf ./reports/*",
    "format": "prettier --write '**/*.{ts,md,json}'",
    "format:check": "prettier --check '**/*.{ts,md,json}'",
    "report:generate": "allure generate ./reports/allure-results --clean -o ./reports/allure-report",
    "report:open": "allure open ./reports/allure-report",
    "report": "npm run report:generate && npm run report:open"
  },
  "devDependencies": {
    "@cucumber/cucumber": "10.9.0",
    "@types/chai": "^4.3.5",
    "@types/node": "^20.11.0",
    "@wdio/allure-reporter": "9.29.1",
    "@wdio/cli": "9.29.1",
    "@wdio/cucumber-framework": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/spec-reporter": "9.29.1",
    "@wdio/types": "9.29.1",
    "@wdio/utils": "9.29.1",
    "allure-commandline": "^2.43.0",
    "appium": "^3.5.2",
    "appium-uiautomator2-driver": "^8.0.1",
    "appium-xcuitest-driver": "^11.17.1",
    "chai": "^4.3.8",
    "dotenv": "^16.3.1",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.0",
    "webdriverio": "9.29.1"
  }
}
