# Sample environment values for Appium + WebdriverIO
#
# Both platforms are configured at once. `npm run test:android` and
# `npm run test:ios` each pick their own block automatically, so nothing
# here needs to be switched or commented out to run the other platform.

# Android
ANDROID_APP_PATH=./apps/android/SwagLabs.apk
ANDROID_PLATFORM_VERSION=13.0
ANDROID_DEVICE_NAME=Android Emulator
ANDROID_AUTOMATION_NAME=UiAutomator2
APP_PACKAGE=com.swaglabsmobileapp
APP_ACTIVITY=.MainActivity

# iOS
IOS_APP_PATH=./apps/ios/SwagLabs.app
IOS_PLATFORM_VERSION=17.5
IOS_DEVICE_NAME=iPhone 15
IOS_AUTOMATION_NAME=XCUITest
BUNDLE_ID=            # only needed if the app is already installed on the target
UDID=                 # only needed when targeting a real device instead of the simulator

APPIUM_HOST=0.0.0.0
APPIUM_PORT=4723
SAUCE_USERNAME=
SAUCE_ACCESS_KEY=
SAUCE_REGION=us
